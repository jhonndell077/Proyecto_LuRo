{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "site": "luro-control",
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/",
        "destination": "/app.html",
        "type": 302
      },
      {
        "source": "/index.html",
        "destination": "/app.html",
        "type": 302
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/app.html"
      }
    ]
  }
}
