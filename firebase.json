{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "site": "luro-control",
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/app",
        "destination": "/app.html",
        "type": 301
      },
      {
        "source": "/acceder",
        "destination": "/acceder.html",
        "type": 301
      },
      {
        "source": "/descargar",
        "destination": "/descargar.html",
        "type": 301
      }
    ]
  }
}
