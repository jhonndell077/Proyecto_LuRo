		removePopup();
		document.body.style.cursor = '';
		document.removeEventListener('mouseover', onInspectHover, true);
		document.removeEventListener('click', onInspectClick, true);
		document.removeEventListener('keydown', onInspectKey, true);
	}

	// Stop inspect mode but KEEP the popup visible
	function stopInspectKeepPopup() {
		inspectMode = false;
		hideHighlight();
		hideHintBar();
		document.body.style.cursor = '';
		document.removeEventListener('mouseover', onInspectHover, true);
		document.removeEventListener('click', onInspectClick, true);
		document.removeEventListener('keydown', onInspectKey, true);
		// Update floating button state
		const floatBtn = document.getElementById('ag-inspect-float-btn');
		if (floatBtn) {
			floatBtn.innerHTML = '<span class="ag-btn-emoji">🔍</span> AG Inspector';
			floatBtn.classList.remove('ag-active');
		}
	}

	function onInspectHover(e) {
		if (!inspectMode) return;
		const el = e.target;
		if (el === highlightOverlay || el === popup || (popup && popup.contains(el))) return;
		const floatBtn = document.getElementById('ag-inspect-float-btn');
		if (el === floatBtn || (floatBtn && floatBtn.contains(el))) return;
		updateHighlight(el);
	}

	function onInspectClick(e) {
		if (!inspectMode) return;
		const el = e.target;
		if (el === popup || (popup && popup.contains(el)) || el === hintBar || (hintBar && hintBar.contains(el))) return;
		const floatBtn = document.getElementById('ag-inspect-float-btn');
		if (el === floatBtn || (floatBtn && floatBtn.contains(el))) return;
		e.preventDefault();
		e.stopPropagation();
		e.stopImmediatePropagation();
		showPopup(el, e.clientX, e.clientY);
		stopInspectKeepPopup();
	}

	function onInspectKey(e) {
		if (e.key === 'Escape') {
			e.preventDefault();
			e.stopPropagation();
			disableInspect();
		}
	}

	// --- Activate with Ctrl+Shift+Click ---
	document.addEventListener('click', function(e) {
		if (e.ctrlKey && e.shiftKey && !inspectMode) {
			e.preventDefault();
			e.stopPropagation();
			enableInspect();
		}
	}, true);

	// --- Also listen for keyboard shortcut Ctrl+Shift+E to toggle ---
	document.addEventListener('keydown', function(e) {
		if (e.ctrlKey && e.shiftKey && e.key === 'E' && !inspectMode) {
			e.preventDefault();
			enableInspect();
		}
	}, true);

	// --- Listen for message from parent (extension) ---
	window.addEventListener('message', function(event) {
		if (event.data && event.data.command === 'ag-start-inspect') {
			enableInspect();
		}
	});

	// --- Floating Inspector Button (always visible) ---
	function createFloatingButton() {
		injectStyles();

		// Add floating button styles
		const btnStyle = document.createElement('style');
		btnStyle.id = 'ag-float-btn-styles';
		btnStyle.textContent = `
			.ag-float-btn {
				position: fixed;
				bottom: 16px;
				left: 16px;
				z-index: 999990;
				display: flex;
				align-items: center;
				gap: 6px;
				background: linear-gradient(135deg, #7B2FBE, #5B1F9E);
				color: #fff;
				border: none;
				padding: 8px 14px;
				border-radius: 24px;
				font-size: 12px;
				font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
				font-weight: 600;
				cursor: pointer;
				box-shadow: 0 4px 16px rgba(123, 47, 190, 0.4);
				transition: all 0.2s ease;
				opacity: 0.85;
			}
			.ag-float-btn:hover {
				opacity: 1;
				transform: translateY(-2px);
				box-shadow: 0 6px 24px rgba(123, 47, 190, 0.6);
			}
			.ag-float-btn:active {
				transform: translateY(0);
			}
			.ag-float-btn.ag-active {
				background: linear-gradient(135deg, #e74c3c, #c0392b);
				box-shadow: 0 4px 16px rgba(231, 76, 60, 0.4);
				animation: ag-btn-pulse 1.5s infinite;
			}
			@keyframes ag-btn-pulse {
				0%,100% { box-shadow: 0 4px 16px rgba(231, 76, 60, 0.4); }
				50% { box-shadow: 0 4px 24px rgba(231, 76, 60, 0.7); }
			}
			.ag-float-btn .ag-btn-emoji {
				font-size: 16px;
			}
		`;
		document.head.appendChild(btnStyle);

		const btn = document.createElement('button');
		btn.className = 'ag-float-btn';
		btn.id = 'ag-inspect-float-btn';
		btn.innerHTML = '<span class="ag-btn-emoji">🔍</span> AG Inspector';
		btn.title = 'Bật AG Inspector để chọn element và copy CSS/XPath/JS (Ctrl+Shift+E)';

		btn.addEventListener('click', function(e) {
			e.preventDefault();
			e.stopPropagation();
			if (inspectMode) {
				disableInspect();
				btn.innerHTML = '<span class="ag-btn-emoji">🔍</span> AG Inspector';
				btn.classList.remove('ag-active');
			} else {
				enableInspect();
				btn.innerHTML = '<span class="ag-btn-emoji">✕</span> Đang chọn...';
				btn.classList.add('ag-active');
			}
		});

		document.body.appendChild(btn);

		// Update button state when inspect is disabled by ESC or element selection
		const origDisable = disableInspect;
		disableInspect = function() {
			origDisable();
			const floatBtn = document.getElementById('ag-inspect-float-btn');
			if (floatBtn) {
				floatBtn.innerHTML = '<span class="ag-btn-emoji">🔍</span> AG Inspector';
				floatBtn.classList.remove('ag-active');
			}
		};
	}

	// Auto-create the floating button when page loads
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', createFloatingButton);
	} else {
		createFloatingButton();
	}

	// --- RGB to Hex converter ---
	function rgbToHex(rgb) {
		if (!rgb) return '';
		if (rgb.startsWith('#')) return rgb;
		const match = rgb.match(/rgba?\((\d+),\s*(\d+),\s*(\d+)/);
		if (!match) return rgb;
		const r = parseInt(match[1]);
		const g = parseInt(match[2]);
		const b = parseInt(match[3]);
		return '#' + [r, g, b].map(x => x.toString(16).padStart(2, '0')).join('');
	}
})();

// ============================================================
// AG Zoom — Forward Ctrl+/- from iframe to parent webview
// ============================================================
(function() {
	document.addEventListener('keydown', function(e) {
		if (e.ctrlKey || e.metaKey) {
			if (e.key === '=' || e.key === '+') {
				e.preventDefault();
				window.parent.postMessage({ command: 'ag-zoom-in' }, '*');
			} else if (e.key === '-') {
				e.preventDefault();
				window.parent.postMessage({ command: 'ag-zoom-out' }, '*');
			} else if (e.key === '0') {
				e.preventDefault();
				window.parent.postMessage({ command: 'ag-zoom-reset' }, '*');
			}
		}
	}, true);

	document.addEventListener('wheel', function(e) {
		if (e.ctrlKey || e.metaKey) {
			e.preventDefault();
			window.parent.postMessage({ command: e.deltaY < 0 ? 'ag-zoom-in' : 'ag-zoom-out' }, '*');
		}
	}, { passive: false });
})();
