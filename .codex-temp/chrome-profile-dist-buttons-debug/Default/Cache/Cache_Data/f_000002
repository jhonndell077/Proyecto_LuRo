	// --- Create highlight overlay ---
	function createHighlight() {
		if (highlightOverlay) return;
		highlightOverlay = document.createElement('div');
		highlightOverlay.className = 'ag-inspect-highlight';
		highlightOverlay.style.display = 'none';
		document.body.appendChild(highlightOverlay);
	}

	function updateHighlight(el) {
		if (!highlightOverlay || !el) return;
		const rect = el.getBoundingClientRect();
		highlightOverlay.style.display = 'block';
		highlightOverlay.style.top = rect.top + 'px';
		highlightOverlay.style.left = rect.left + 'px';
		highlightOverlay.style.width = rect.width + 'px';
		highlightOverlay.style.height = rect.height + 'px';
	}

	function hideHighlight() {
		if (highlightOverlay) highlightOverlay.style.display = 'none';
	}

	// --- Show toast ---
	function showToast(msg) {
		const toast = document.createElement('div');
		toast.className = 'ag-inspect-toast';
		toast.textContent = msg;
		document.body.appendChild(toast);
		setTimeout(() => toast.remove(), 1600);
	}

	// --- Copy to clipboard ---
	function copyText(text, label) {
		navigator.clipboard.writeText(text).then(() => {
			showToast('✓ Đã copy ' + label);
		}).catch(() => {
			// Fallback
			const ta = document.createElement('textarea');
			ta.value = text;
			ta.style.position = 'fixed';
			ta.style.opacity = '0';
			document.body.appendChild(ta);
			ta.select();
			document.execCommand('copy');
			ta.remove();
			showToast('✓ Đã copy ' + label);
		});
		removePopup();
	}

	// --- Show popup ---
	function showPopup(el, x, y) {
		removePopup();
		currentTarget = el;

		const cssSelector = getCssSelector(el);
		const xpath = getXPath(el);
		const jsQuery = "document.querySelector('" + cssSelector.replace(/'/g, "\\'") + "')";
		const outerHTML = el.outerHTML;
		const textContent = (el.textContent || '').trim().substring(0, 200);
		const tagInfo = el.tagName.toLowerCase() + (el.id ? '#' + el.id : '') + (el.className && typeof el.className === 'string' ? '.' + el.className.trim().split(/\s+/).filter(c => !c.startsWith('ag-inspect')).join('.') : '');

		// Get computed colors
		const computed = window.getComputedStyle(el);
		const bgColor = computed.backgroundColor;
		const textColor = computed.color;
		const borderColor = computed.borderColor;

		popup = document.createElement('div');
		popup.className = 'ag-inspect-popup';

		popup.innerHTML = '<div class="ag-popup-title">' +
			'<span><span class="ag-tag">AG</span> &nbsp;' + tagInfo.substring(0, 40) + '</span>' +
			'<span class="ag-popup-close" id="ag-popup-close">✕</span>' +
			'</div>';

		const items = [
			{ label: 'CSS Selector', value: cssSelector },
			{ label: 'XPath', value: xpath },
			{ label: 'JS Query', value: jsQuery },
			{ label: 'Text Content', value: textContent },
			{ label: 'Outer HTML', value: outerHTML.substring(0, 500) },
		];

		// Color items with color swatch
		const colorItems = [];
		if (bgColor && bgColor !== 'rgba(0, 0, 0, 0)' && bgColor !== 'transparent') {
			colorItems.push({ label: 'Background', value: rgbToHex(bgColor), raw: bgColor });
		}
		if (textColor) {
			colorItems.push({ label: 'Text Color', value: rgbToHex(textColor), raw: textColor });
		}
		if (borderColor && borderColor !== textColor && borderColor !== 'rgb(0, 0, 0)') {
			colorItems.push({ label: 'Border', value: rgbToHex(borderColor), raw: borderColor });
		}

		items.forEach(item => {
			if (!item.value) return;
			const btn = document.createElement('button');
			btn.className = 'ag-inspect-btn';
			btn.innerHTML = '<span class="ag-btn-label">' + item.label + '</span>' +
				'<span class="ag-btn-preview">' + escapeHtml(item.value.substring(0, 30)) + '</span>';
			btn.addEventListener('click', (e) => {
				e.stopPropagation();
				e.preventDefault();
				copyText(item.value, item.label);
			});
			popup.appendChild(btn);
		});

		// Add color items with swatches
		if (colorItems.length > 0) {
			const divider = document.createElement('div');
			divider.style.cssText = 'height:1px;background:#313244;margin:4px 8px;';
			popup.appendChild(divider);

			colorItems.forEach(ci => {
				const btn = document.createElement('button');
				btn.className = 'ag-inspect-btn';
				btn.innerHTML = '<span class="ag-color-swatch" style="background:' + ci.raw + ';"></span>' +
					'<span class="ag-btn-label">' + ci.label + '</span>' +
					'<span class="ag-btn-preview">' + ci.value + '</span>';
				btn.addEventListener('click', (e) => {
					e.stopPropagation();
					e.preventDefault();
					copyText(ci.value, ci.label);
				});
				popup.appendChild(btn);
			});
		}

		// Position popup
		let posX = x + 10;
		let posY = y + 10;
		document.body.appendChild(popup);

		const popupRect = popup.getBoundingClientRect();
		if (posX + popupRect.width > window.innerWidth - 10) posX = x - popupRect.width - 10;
		if (posY + popupRect.height > window.innerHeight - 10) posY = y - popupRect.height - 10;
		if (posX < 5) posX = 5;
		if (posY < 5) posY = 5;

		popup.style.left = posX + 'px';
		popup.style.top = posY + 'px';

		document.getElementById('ag-popup-close').addEventListener('click', (e) => {
			e.stopPropagation();
			removePopup();
		});

		// Close popup on outside click
		setTimeout(() => {
			document.addEventListener('click', onOutsideClick, true);
		}, 100);
	}

	function onOutsideClick(e) {
		if (popup && !popup.contains(e.target)) {
			removePopup();
		}
	}

	function removePopup() {
		if (popup) {
			popup.remove();
			popup = null;
		}
		hideHighlight();
		document.removeEventListener('click', onOutsideClick, true);
	}

	function escapeHtml(text) {
		const div = document.createElement('div');
		div.textContent = text;
		return div.innerHTML;
	}

